generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Article {
  id                 String    @id @default(cuid())
  title              String
  description        String?
  content            String?
  url                String    @unique
  imageUrl           String?
  publishedAt        DateTime
  source             String
  sourceUrl          String?
  category           String
  sentiment          String    @default("neutral")
  sentimentScore     Float     @default(0)
  aiSummary          String?
  aiBullets          String?
  isRead             Boolean   @default(false)
  readAt             DateTime?
  isSaved            Boolean   @default(false)
  fetchedAt          DateTime  @default(now())
  severity           String    @default("")
  isCriticalBreaking Boolean   @default(false)
  criticalPushedAt   DateTime?

  @@index([publishedAt(sort: Desc)])
  @@index([category, publishedAt(sort: Desc)])
  @@index([readAt])
  @@index([sentiment])
  @@index([severity])
}

model TopStory {
  id         String   @id @default(cuid())
  title      String
  summary    String
  category   String
  articleIds String
  sources    String
  sentiment  String   @default("neutral")
  createdAt  DateTime @default(now())
}

model UserPreferences {
  id                  String   @id @default("default")
  positiveRatio       Float    @default(0.4)
  neutralRatio        Float    @default(0.4)
  negativeRatio       Float    @default(0.2)
  enabledCategories   String   @default("technology,science,business,world,positive")
  refreshIntervalMins Int      @default(60)
  moodPreset          String   @default("balanced")
  avoidTopics         String   @default("")
  hiddenSources       String   @default("")
  sessionSize         Int      @default(15)
  depthMode           String   @default("skim")
  enabledSources      String   @default("")
  pushEnabled         Boolean  @default(false)
  quietHoursEnabled   Boolean  @default(false)
  quietHoursStart     String   @default("22:00")
  quietHoursEnd       String   @default("07:00")
  updatedAt           DateTime @updatedAt
}

model AppState {
  id                String    @id @default("default")
  lastRefreshed     DateTime?
  lastImapPoll      DateTime?
  lastOpenedAt      DateTime?
  lastBreakingCheck DateTime?
  vapidPublic       String?
  vapidPrivate      String?
  updatedAt         DateTime  @updatedAt
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ArticleFeedback {
  id        String   @id @default(cuid())
  articleId String
  feedback  String
  source    String?
  createdAt DateTime @default(now())

  @@index([articleId])
  @@index([feedback, createdAt])
}

model SourceWeight {
  id           String   @id @default(cuid())
  source       String   @unique
  weight       Float    @default(1.0)
  lastAdjusted DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
